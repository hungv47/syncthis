# Union-sync MCP servers across every agent — the unique core. Live writes against the
# sandbox HOME (build.sh seeds context7/playwright/github/filesystem across four agents).
Output docs/demos/out/mcp-sync.gif

Set Shell bash
Set FontSize 16
Set Width 1180
Set Height 760
Set Padding 18
Set TypingSpeed 55ms

Hide
Type "export PS1='$ '"
Enter
Type "clear"
Enter
Show

Sleep 500ms
Type "syncthis mcp sync"
Sleep 400ms
Enter
Sleep 5s
