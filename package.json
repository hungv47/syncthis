{
  "name": "@hungv47/syncthis",
  "version": "0.2.1",
  "description": "Keep your AI tools in sync. Cross-pollinate MCP server configs across 11 coding agents (Claude, Cursor, Codex, Gemini, Kimi, OpenCode, OpenClaw, Hermes, Windsurf, Antigravity, Copilot). Skills delegated to npx skills. Install with mcpm or npx skills add; sync with this.",
  "type": "module",
  "license": "MIT",
  "author": "Le Vinh Hung <levinhhungg@gmail.com>",
  "homepage": "https://syncthis.forsvn.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hungv47/syncthis.git"
  },
  "bugs": {
    "url": "https://github.com/hungv47/syncthis/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sync",
    "claude",
    "claude-code",
    "cursor",
    "codex",
    "gemini",
    "kimi",
    "opencode",
    "windsurf",
    "antigravity",
    "github-copilot",
    "openclaw",
    "hermes",
    "ai-agents",
    "ai-tools",
    "cli",
    "config-sync",
    "skills"
  ],
  "bin": {
    "syncthis": "bin/syncthis.mjs"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun build ./bin/syncthis.ts --compile --outfile dist/syncthis",
    "prepublishOnly": "bun test && bunx tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "ink": "^7.0.2",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "js-yaml": "^4.1.0",
    "json5": "^2.2.3",
    "react": "^19.2.6",
    "react-devtools-core": "^7.0.1",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
